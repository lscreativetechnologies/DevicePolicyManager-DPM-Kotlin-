<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/accessibilityScreen"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Illustration (Optional) -->
    <ImageView
        android:id="@+id/imageIllustration"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:src="@drawable/lock" />

    <!-- Title -->
    <TextView
        android:id="@+id/textTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/imageIllustration"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Enable Accessibility Access"
        android:textColor="#000000"
        android:textSize="22sp"
        android:textStyle="bold" />

    <!-- Description -->
    <TextView
        android:id="@+id/textDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/textTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:text="To protect your loan account and prevent unauthorized activity, please enable Accessibility Access. We use this only to secure your device in case of fraud or misuse as per your loan agreement."
        android:textAlignment="center"
        android:textColor="#666666"
        android:textSize="15sp" />

    <!-- CTA Button -->
    <Button
        android:id="@+id/btnEnableAccessibility"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:backgroundTint="#4CAF50"
        android:text="Enable Accessibility"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="normal" />
</RelativeLayout>
